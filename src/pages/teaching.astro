---
import BaseLayout from '../layouts/BaseLayout.astro';
import Section from '../components/Section.astro';
---

<BaseLayout
  title="Teaching"
  description="Teaching activities in generative and agentic AI for healthcare and applied computing."
>
  <Section title="Teaching">
    <div class="list">
      <article class="item">
        <h3>Generative and Agentic AI</h3>
        <p class="meta">Hamburg University of Applied Sciences</p>
        <p>
          Course content focuses on practical foundations, modern AI workflows, and responsible
          adoption of generative and agentic systems.
        </p>
      </article>
    </div>
  </Section>
</BaseLayout>
