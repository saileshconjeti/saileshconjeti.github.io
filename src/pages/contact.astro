  description="Professional contact routes for collaboration in medical and applied AI."
>
  <Section title="Contact">
    <div class="card">
      <p>
        I welcome professional conversations on medical AI, clinical AI validation, generative and
        agentic AI in healthcare, endoscopy workflow software, and teaching collaborations.
      </p>
      <p>
        Please use the contact routes below.
      </p>
    </div>
  </Section>

  <Section title="Professional Contact Routes">
    <div class="list">
      <article class="item">
        <h3>LinkedIn</h3>
        <p>
          <a href="https://www.linkedin.com/in/saileshconjeti/" rel="noopener noreferrer" target="_blank">
            linkedin.com/in/saileshconjeti
          </a>
        </p>
      </article>

      <article class="item">
        <h3>Google Scholar</h3>
        <p>
          <a href="https://scholar.google.com/citations?user=C4eOUHsAAAAJ" rel="noopener noreferrer" target="_blank">
            scholar.google.com/citations?user=C4eOUHsAAAAJ
          </a>
        </p>
      </article>

      <article class="item">
        <h3>GitHub</h3>
        <p>
          <a href="https://github.com/saileshconjeti" rel="noopener noreferrer" target="_blank">
