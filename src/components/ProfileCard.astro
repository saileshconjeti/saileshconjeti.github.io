---
interface Props {
  imageSrc: string;
  imageAlt: string;
}

const { imageSrc, imageAlt } = Astro.props;
---

<section class="card profile-grid">
  <img class="profile-img" src={imageSrc} alt={imageAlt} loading="lazy" />
  <div class="profile-copy">
    <h1>Sailesh Conjeti</h1>
    <p class="lead">
      I work on digital health products and applied AI, with experience across medical device
      software, endoscopy workflows, radiology AI, and medical image computing.
    </p>
    <p class="meta">
      Experience includes Olympus and Siemens Healthineers, with ongoing focus on practical and
      safe use of generative and agentic AI in healthcare.
    </p>
  </div>
</section>
