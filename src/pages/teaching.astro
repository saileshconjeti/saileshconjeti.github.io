---
import BaseLayout from '../layouts/BaseLayout.astro';
import Section from '../components/Section.astro';
---

<BaseLayout
  title="Teaching"
  description="Teaching in generative and agentic AI at Hamburg University of Applied Sciences."
>
  <Section title="Teaching">
    <div class="list">
      <article class="item">
        <h3>Generative and Agentic AI</h3>
        <p class="meta">Hamburg University of Applied Sciences</p>
        <p>
          I teach Generative and Agentic AI at Hamburg University of Applied Sciences. The course
          covers foundations and applied project work, including large language models,
          retrieval-augmented generation, agentic AI patterns, evaluation, and practical
          prototyping.
        </p>
        <p>
          The course includes capstone projects where students build and present working AI
          prototypes.
        </p>
      </article>
    </div>
  </Section>
</BaseLayout>
