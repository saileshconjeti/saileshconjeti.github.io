---
import BaseLayout from '../layouts/BaseLayout.astro';
import Section from '../components/Section.astro';
---

<BaseLayout
  title="Patents"
  description="Public invention themes related to applied AI in healthcare."
>
  <Section title="Patents">
    <div class="card">
      <p>
        My patent and invention work covers applied AI in healthcare.
      </p>
      <p>Main themes include:</p>
      <ul>
        <li>AI workflow integration</li>
        <li>Clinical reporting</li>
        <li>Medical imaging</li>
        <li>Clinical natural language processing</li>
        <li>Healthcare interoperability</li>
        <li>Workflow orchestration</li>
        <li>AI-assisted documentation</li>
        <li>Metadata quality</li>
        <li>Endoscopy and radiology workflow support</li>
      </ul>
      <p>
        This page currently summarizes invention themes. Public patent references can be added as
        individual entries after verification.
      </p>
    </div>
  </Section>
</BaseLayout>
