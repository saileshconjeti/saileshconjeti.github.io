---
import BaseLayout from '../layouts/BaseLayout.astro';
import Section from '../components/Section.astro';
---

<BaseLayout
  title="Patents"
  description="Public invention themes related to medical software, imaging AI, and workflow intelligence."
>
  <Section title="Patents and Invention Themes">
    <div class="card">
      <p>
        This page summarizes public invention themes from my work in medical software and AI.
        Patent numbers are intentionally omitted here unless explicitly available in public repository
        materials.
      </p>
      <p>
        Themes include AI-assisted endoscopy workflows, medical image analysis methods, and software
        systems that support clinical decision workflows.
      </p>
    </div>
  </Section>
</BaseLayout>
