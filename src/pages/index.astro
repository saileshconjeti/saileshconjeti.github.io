---
import BaseLayout from '../layouts/BaseLayout.astro';
import ProfileCard from '../components/ProfileCard.astro';
import Section from '../components/Section.astro';
---

<BaseLayout
  title="About"
  description="Sailesh Conjeti works on digital health products, medical device software, and applied AI in healthcare."
>
  <div class="home-hero">
    <ProfileCard imageSrc="/images/Sailesh_Conjeti.png" imageAlt="Portrait of Sailesh Conjeti" />
  </div>

  <Section title="About">
    <div class="card home-summary">
      <p>
        I work on digital health products, medical device software, and applied AI in healthcare.
      </p>
      <p>
        I currently focus on Endoscopy Workflow Management at Olympus, including workflow automation,
        voice reporting, AI-assisted documentation, structured reporting, and interoperability.
      </p>
      <p>
        Before Olympus, I worked at Siemens Healthineers on AI products for radiology image analysis,
        including AI-Rad Companion Chest X-ray.
      </p>
      <p>
        My earlier work was in medical image computing research, including computational
        neuroimaging, digital pathology, retinal imaging, and deep learning for medical image
        analysis.
      </p>
      <p>
        I also teach Generative and Agentic AI at Hamburg University of Applied Sciences.
      </p>
    </div>
  </Section>

  <Section title="Focus Areas">
    <div class="list home-focus">
      <article class="item">
        <h3>Digital Health Products</h3>
        <p class="meta">Product development for healthcare software and clinical workflows.</p>
      </article>
      <article class="item">
        <h3>Endoscopy Workflow Management</h3>
        <p class="meta">Workflow automation, voice reporting, AI-assisted documentation, structured reporting, and interoperability.</p>
      </article>
      <article class="item">
        <h3>Radiology AI</h3>
        <p class="meta">AI products for radiology image analysis, including AI-Rad Companion Chest X-ray.</p>
      </article>
      <article class="item">
        <h3>Medical Image Computing Research and Teaching</h3>
        <p class="meta">Research across neuroimaging, digital pathology, retinal imaging, and teaching Generative and Agentic AI.</p>
      </article>
    </div>
  </Section>
</BaseLayout>
