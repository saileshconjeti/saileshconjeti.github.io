---
import BaseLayout from '../layouts/BaseLayout.astro';
import Section from '../components/Section.astro';
---

<BaseLayout
  title="Products"
  description="Selected digital health and AI products across endoscopy and radiology."
>
  <Section title="Products">
    <div class="list">
      <article class="item">
        <h3>Endoscopy Workflow Management</h3>
        <p>
          Product and software work focused on procedure workflow, documentation, and operational
          coordination in endoscopy settings.
        </p>
      </article>

      <article class="item">
        <h3>OLYSENSE / Intelligent Endoscopy</h3>
        <p>
          AI-enabled capabilities supporting endoscopy workflows with emphasis on practical clinical
          integration and usability.
        </p>
      </article>

      <article class="item">
        <h3>AI Endoscopy Products</h3>
        <p>
          Development and productization of AI functionality for endoscopy use cases, aligned with
          medical software requirements.
        </p>
      </article>

      <article class="item">
        <h3>AI-Rad Companion</h3>
        <p>
          Product work in radiology AI solutions designed to support image interpretation workflows.
        </p>
      </article>

      <article class="item">
        <h3>AI-Rad Companion Chest X-ray</h3>
        <p>
          Focused radiology AI product area for chest X-ray support within clinical routine.
        </p>
      </article>
    </div>
  </Section>
</BaseLayout>
