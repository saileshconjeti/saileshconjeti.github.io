---

<BaseLayout
  title="Publications"
  description="Selected and broader publications across medical image computing, clinical AI evaluation, and workflow-oriented healthcare AI."
>
  <Section title="Publications">
    <p>
      This page provides a curated publication overview across medical image retrieval,
      neuroimaging, OCT/IVUS analysis, computational pathology, and clinical AI evaluation.
    </p>
    <p class="meta">
      The list is a deduplicated compilation based on <a href={scholarProfile} rel="noopener noreferrer" target="_blank">Google Scholar</a>, PubMed,
      DBLP, and publisher metadata, and may not be exhaustive.
    </p>
  </Section>

  <Section title="Selected Publications">
    <div class="list">
      {selectedPublications.map((publication) => (
        <article class="item">
          <h3>{publication.title}</h3>
          <p class="meta">{publication.authors}. <em>{publication.venue}</em>, {publication.year}.</p>
          <p>{publication.summary}</p>
          <p class="meta">
            {publication.links.map((link, index) => (
              <>
                {index > 0 ? ' | ' : ''}
                <a href={link.url} rel="noopener noreferrer" target="_blank">{link.label}</a>
              </>
            ))}
          </p>
        </article>
      ))}
    </div>
  </Section>

  <Section title="Broader Publication List (Grouped by Theme)">
    {broaderByTheme.map((group) => (
      <div class="section">
        <h3>{group.theme}</h3>
        <div class="list">
          {group.publications.map((publication) => (
            <article class="item">
              <h3>{publication.title}</h3>
              <p class="meta">{publication.authors}. <em>{publication.venue}</em>, {publication.year}.</p>
              <p>{publication.summary}</p>
              <p class="meta">
                {publication.links.map((link, index) => (
                  <>
                    {index > 0 ? ' | ' : ''}
                    <a href={link.url} rel="noopener noreferrer" target="_blank">{link.label}</a>
                  </>
                ))}
              </p>
            </article>
          ))}
        </div>
      </div>
    ))}
  </Section>
</BaseLayout>
